# =============================================================================
# Relay — environment variables example
# Copy to .env and fill every value. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Supabase Postgres or local Docker postgres)
# Docker compose example: postgresql+asyncpg://relay:relay@localhost:5432/relay
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://relay:relay@localhost:5432/relay

# -----------------------------------------------------------------------------
# Redis (arq queue + cache)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Supabase (auth + DB hosting)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<supabase-anon-key>
SUPABASE_SERVICE_KEY=<supabase-service-role-key>
# Optional: enables HS256 token verification for local/test tokens
SUPABASE_JWT_SECRET=
# Optional: override JWKS issuer URL (defaults to SUPABASE_URL)
SUPABASE_JWT_ISSUER=

# -----------------------------------------------------------------------------
# Moss retrieval service (moss.dev — built-in embeddings, hybrid search)
# -----------------------------------------------------------------------------
MOSS_PROJECT_ID=<moss-project-id>
MOSS_PROJECT_KEY=<moss-project-key>
MOSS_INDEX_NAME=relay
MOSS_MEMORY_INDEX_NAME=relay-memory
# Hybrid search weight: 0=keyword, 1=semantic, 0.5=balanced
MOSS_HYBRID_ALPHA=0.5

# -----------------------------------------------------------------------------
# LiveKit (audio transport + room management)
# -----------------------------------------------------------------------------
LIVEKIT_URL=wss://<your-project>.livekit.cloud
LIVEKIT_API_KEY=<livekit-api-key>
LIVEKIT_API_SECRET=<livekit-api-secret>
# STT runs through LiveKit Inference — a model string routed by LiveKit and billed
# against LiveKit credits (no separate STT account/key). Override if desired.
LIVEKIT_STT_MODEL=assemblyai/universal-streaming
# Endpointing: trailing-silence delay (seconds) before a turn is finalized. Lower =
# faster finals after the speaker stops. LiveKit's defaults are 0.5 / 3.0.
STT_MIN_ENDPOINTING_DELAY=0.2
STT_MAX_ENDPOINTING_DELAY=1.5
# Dispatch NAME the agent worker registers with (explicit dispatch). The gateway
# dispatches this name to each session room; SIP dispatch rules target it for
# inbound phone calls.
LIVEKIT_AGENT_NAME=relay-agent
# Fixed room for the inbound-phone demo. The agent transcribes whoever joins it
# (a SIP caller OR the rep's browser mic); the dashboard's Live view watches it.
LIVEKIT_DEMO_ROOM=relay-demo

# -----------------------------------------------------------------------------
# Unsiloed (document parsing — async job API)
# -----------------------------------------------------------------------------
UNSILOED_API_KEY=<unsiloed-api-key>
UNSILOED_BASE_URL=https://prod.visionapi.unsiloed.ai

# -----------------------------------------------------------------------------
# TrueFoundry AI Gateway (LLM routing — /chat/completions)
# -----------------------------------------------------------------------------
TFY_API_KEY=<tfy-api-key>
TFY_GATEWAY_URL=https://gateway.truefoundry.ai
# Provider-prefixed chat model id routed by TFY
TFY_MODEL=anthropic/claude-sonnet-4-5
# Fast model used ONLY for live card synthesis (1–2 sentence cited answers) — cheaper
# and much lower latency than Sonnet. Falls back to TFY_MODEL + fallbacks if it errors.
TFY_FAST_MODEL=anthropic/claude-haiku
# Max output tokens for a card (cards are 1–2 sentences — keep tight for latency).
CARD_MAX_TOKENS=150
# Comma-separated fallback models tried (in order) if the primary fails, e.g. qwen/qwen-plus
TFY_FALLBACK_MODELS=

# -----------------------------------------------------------------------------
# Anthropic (Claude — reached THROUGH the TFY gateway; key not needed when using TFY)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=<anthropic-api-key>

# -----------------------------------------------------------------------------
# MiniMax (whisper-back TTS — Speech-02-Turbo). Requires key + GroupId.
# -----------------------------------------------------------------------------
MINIMAX_API_KEY=<minimax-api-key>
MINIMAX_GROUP_ID=<minimax-group-id>
MINIMAX_BASE_URL=https://api.minimax.io
MINIMAX_TTS_MODEL=speech-02-turbo
MINIMAX_VOICE_ID=male-qn-qingse

# -----------------------------------------------------------------------------
# Qwen / Alibaba DashScope (embeddings — text-embedding-v3 1024d; pgvector fallback)
# -----------------------------------------------------------------------------
QWEN_API_KEY=<qwen-dashscope-api-key>
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_EMBEDDING_MODEL=text-embedding-v3

# -----------------------------------------------------------------------------
# AWS / S3 (raw file storage)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=<aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<aws-secret-access-key>
AWS_REGION=us-east-1
S3_BUCKET=relay-documents

# -----------------------------------------------------------------------------
# Slack (lead routing notifications) — OPTIONAL.
# If unset, Intake lead routing skips the Slack post and logs instead of erroring.
# -----------------------------------------------------------------------------
SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Application settings
# -----------------------------------------------------------------------------
# CORS — comma-separated list of allowed origins, with NO trailing slash.
# Include your dev origin + the deployed frontend, e.g.:
#   FRONTEND_ORIGIN=http://localhost:3000,https://relay-omega-five.vercel.app
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:3000

# Model selector: claude | qwen | minimax
LLM_MODEL=claude

# Embedding dimension (must match the model; default 1024)
EMBEDDING_DIM=1024

# Demo organisation UUID — the single tenant used by seed + local dev
DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000001

# Postgres role used by the application (must match RLS policy setup)
APP_DB_ROLE=relay_app
