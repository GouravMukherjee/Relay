# Relay backend — environment template.
# Copy to `.env` for local docker-compose. NEVER commit the real .env.
# On TrueFoundry these become Secrets (see deploy/ specs), not a committed file.

# ── Database ────────────────────────────────────────────────────────────────
# Local compose points at the bundled pgvector container (host = "postgres").
# In prod, point this at managed Postgres (Neon/Supabase/RDS) with pgvector on.
DATABASE_URL=postgresql://relay:relay@postgres:5432/relay

# ── Internal service URLs ───────────────────────────────────────────────────
# Gateway/worker call the retrieval service by this URL. Intra-cluster in prod.
RETRIEVAL_URL=http://retrieval:8001

# ── Moss (primary retrieval index, <10ms) ───────────────────────────────────
MOSS_API_KEY=replace-me
MOSS_ENDPOINT=https://api.moss.example/v1

# ── LiveKit (audio transport) ───────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=replace-me
LIVEKIT_API_SECRET=replace-me

# ── STT (streaming speech-to-text) ──────────────────────────────────────────
DEEPGRAM_API_KEY=replace-me

# ── LLM synthesis ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=replace-me
ANTHROPIC_MODEL=claude-opus-4-8

# ── Doc parsing (ingestion) ─────────────────────────────────────────────────
UNSILOED_API_KEY=replace-me

# ── App config ──────────────────────────────────────────────────────────────
LOG_LEVEL=info
EMBEDDING_DIM=1024
