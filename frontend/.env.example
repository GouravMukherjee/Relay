# Relay frontend configuration.
# Copy to .env.local to override. Defaults run the standalone demo engine.

# Run against the in-browser demo engine (replays DEMO_SCRIPT beats, no backend).
# Set to false to use the real FastAPI gateway + WebSocket.
VITE_USE_MOCK=true

# REST base path (proxied to the gateway in dev via vite.config.ts).
VITE_API_BASE=/api/v1

# Where the Vite dev proxy forwards /api and /ws (the FastAPI gateway).
VITE_GATEWAY_URL=http://localhost:8000

# Optional explicit WebSocket origin (e.g. ws://localhost:8000). If unset,
# the frontend derives it from window.location + the session's ws_url.
# VITE_WS_BASE=
