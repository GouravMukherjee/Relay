# Relay frontend configuration.
# Copy to .env.local and adjust. Two things matter: the toggle and the backend IP.

# ── The toggle ────────────────────────────────────────────────────────────────
# true  → DEMO state: runs the in-browser mock engine, no network. (default)
# false → FUNCTIONAL site: connects to the real backend at VITE_BACKEND_URL.
VITE_DEMO_MODE=true

# ── Backend IP / origin ───────────────────────────────────────────────────────
# Where the FastAPI gateway lives. Accepts a bare IP[:port] or a full URL.
# REST is served at <backend>/api/v1, WebSocket at <backend>/ws.
# The backend must allow CORS from the frontend origin (or use the proxy below).
VITE_BACKEND_URL=http://192.168.1.50:8000

# ── Optional: same-origin proxy (avoids CORS entirely) ───────────────────────
# When VITE_API_BASE is a RELATIVE path the browser calls THIS origin and a proxy
# forwards to the backend — no cross-origin request, no CORS preflight:
#   - Local dev: the Vite dev server proxies /api + /ws (see vite.config.ts).
#   - Vercel:    vercel.json rewrites /api/* to the backend (server-side proxy).
# WebSockets can't be proxied through Vercel, so point them straight at the
# backend with VITE_WS_BASE (a WS handshake is not subject to CORS).
#
# Recommended Vercel env (unblocks the CORS error WITHOUT a backend change):
#   VITE_DEMO_MODE=false
#   VITE_BACKEND_URL=https://api.riyanshomelab.com
#   VITE_API_BASE=/api/v1
#   VITE_WS_BASE=wss://api.riyanshomelab.com
# VITE_API_BASE=/api/v1
# VITE_WS_BASE=wss://api.riyanshomelab.com

# LiveKit Cloud URL — the browser joins this room and publishes the mic so the
# agent worker can transcribe live audio (functional mode). Without it, live audio
# is disabled and only manual typed queries produce cards.
VITE_LIVEKIT_URL=wss://<your-project>.livekit.cloud

# Supabase project credentials (required when VITE_USE_MOCK=false).
# Find these at https://app.supabase.com → project → Settings → API.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>
